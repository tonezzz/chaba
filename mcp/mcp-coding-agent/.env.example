# mcp-coding-agent local overrides
# Copy this file to .env and customize any values you need to override locally.

# Core server settings
MCP_CODING_AGENT_PORT=8350
MCP_CODING_AGENT_HOST=127.0.0.1

# LLM backend (OpenAI-compatible)
# Set one of:
#   MCP_CODING_AGENT_LLM_BASE_URL  – e.g. https://api.openai.com
#   GLAMA_API_URL                   – shared fallback
MCP_CODING_AGENT_LLM_BASE_URL=
MCP_CODING_AGENT_LLM_API_KEY=
MCP_CODING_AGENT_LLM_MODEL=

# Optional overrides
# MCP_CODING_AGENT_LLM_TEMPERATURE=0
# MCP_CODING_AGENT_JSON_LIMIT=4mb
# MCP_CODING_AGENT_SSE_HEARTBEAT_MS=15000
