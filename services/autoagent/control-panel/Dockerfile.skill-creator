# Skill Creator Standalone Server
# Runs only the skill creator UI on port 8080

FROM python:3.11-slim

# Install aiohttp
RUN pip install --no-cache-dir aiohttp

# Copy skill creator files
COPY skill-creator-server.py /app/skill-creator-server.py
COPY static/ /app/static/

# Set working directory
WORKDIR /app

# Expose port
EXPOSE 8080

# Run the skill creator server
CMD ["python3", "/app/skill-creator-server.py"]
