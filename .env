# Environment overrides for docker-compose
# Copy this file and edit as needed.

# GPU selection (default: all)
NVIDIA_VISIBLE_DEVICES=all

# Default iterations for training
ITERATIONS=30000

# COLMAP camera model (OPENCV recommended for most cameras)
CAMERA_MODEL=OPENCV

# Video frame extraction rate (frames per second)
FPS=2

# Nerfstudio method override
METHOD=splatfacto

# Variants method override: 2dgs | mip | gof
VARIANT=2dgs
