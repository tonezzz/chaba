# =============================================================================
# idc1-assistance Stack Environment Variables
# =============================================================================
# NOTE: For Portainer git-backed stacks, these values must be set in the
# Portainer UI (Stack > Environment Variables) as .env files are not
# automatically loaded from the repository.
# =============================================================================

# Database Configuration (merged from idc1-db)
POSTGRES_USER=chaba
POSTGRES_PASSWORD=changeme
POSTGRES_DB=chaba
PGADMIN_EMAIL=admin@chaba.local
PGADMIN_PASSWORD=changeme

# AI Model Configuration
AUTOAGENT_MODEL=openai/gpt-4o-mini
AUTOAGENT_DEBUG=false
AUTOAGENT_API_BASE_URL=https://openrouter.ai/api/v1
AUTOAGENT_FN_CALL=true

# AI API Keys (required for research/enhancement features)
OPENROUTER_API_KEY=
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
HUGGINGFACE_API_KEY=

JARVIS_WS_RECORD=1
JARVIS_IMAGEN_MODEL=imagen-4.0-generate-001
JARVIS_IMAGEN_ALLOWED_MODELS=imagen-4.0-generate-001,imagen-4.0-ultra-generate-001,imagen-4.0-fast-generate-001
JARVIS_CARS_DATA_DIR=/home/chaba/chaba/services/assistance_data/cars/
JARVIS_SHEETS_LOGS_ENABLED=true
JARVIS_SHEETS_LOGS_SHEET_NAME=logs
_JARVIS_SHEETS_LOGS_SPREADSHEET_ID=
GOOGLE_SHEETS_SCOPES=https://www.googleapis.com/auth/spreadsheets
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025
CHABA_SYSTEM_SHEET_NAME=system
MCP_PLAYWRIGHT_BASE_URL=http://host.docker.internal:4054
VITE_JARVIS_WS_URL=wss://assistance.idc1.surf-thailand.com/jarvis/ws/live
JARVIS_FEATURE_MEMO_ENABLED=true
JARVIS_FEATURE_MEMORY_ENABLED=false
JARVIS_FEATURE_KNOWLEDGE_ENABLED=false
REDIS_URL=redis://redis:6379/0
JARVIS_RECENT_DIALOG_TTL_SECONDS=86400
JARVIS_RECENT_DIALOG_MAX_TURNS=60
JARVIS_RECENT_DIALOG_MAX_CHARS=4000