# idc1-assistance stack environment template (Jarvis frontend+backend)
# Copy to .env (kept out of git) and replace secrets marked __REPLACE_ME__.

# Gemini Developer API key (required)
GEMINI_API_KEY=__REPLACE_ME__

# Optional: override model
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Operator verification endpoint (/jarvis/api/verify/status)
# Base URL the endpoint uses when running its backend sub-checks.  The default
# (internal Docker service name) works out-of-the-box within the stack.
# Override when you need to point at a different address (e.g. host-mapped port).
# JARVIS_PUBLIC_BASE_URL=http://jarvis-backend:8018

# Optional: override the frontend root URL used for the bundle-marker check.
# When unset, the endpoint falls back to the internal jarvis-frontend service.
# JARVIS_VERIFY_FRONTEND_BASE_URL=http://jarvis-frontend:80

# Notes:
# - Frontend will be available at http://127.0.0.1:18080/jarvis/
# - Backend health at http://127.0.0.1:18018/health
# - Operator verify at http://127.0.0.1:18018/jarvis/api/verify/status
# - Host Caddy should reverse proxy:
#   /jarvis/* -> 127.0.0.1:18080
#   /jarvis/ws/* -> 127.0.0.1:18018
