# =============================================================================
# JARVIS BACKEND - Environment Variables
# =============================================================================
# This file documents all environment variables used by the Jarvis backend.
# Copy this to Portainer stack environment (idc1-assistance-core) and fill in
# secret values. Portainer is the authoritative source for stack env vars.
#
# DO NOT commit actual secret values to git.
# =============================================================================

# -----------------------------------------------------------------------------
# REQUIRED: Core API Keys (Secrets - set in Portainer only)
# -----------------------------------------------------------------------------
# GEMINI_API_KEY=                          # Google Gemini API key (required)

# -----------------------------------------------------------------------------
# Core Configuration
# -----------------------------------------------------------------------------
JARVIS_PUBLIC_BASE_URL=https://assistance.idc1.surf-thailand.com
JARVIS_ADMIN_TOKEN=                       # Admin access token for protected endpoints

# -----------------------------------------------------------------------------
# Gemini Models
# -----------------------------------------------------------------------------
# Live (voice) model - native audio capable
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Sidecar STT model - used for transcription (lite = higher rate limits)
JARVIS_SIDECAR_STT_MODEL=gemini-flash-lite-latest

# Sidecar STT tuning (optional - defaults are usually fine)
# JARVIS_SIDECAR_STT_CHUNK_S=1.5           # Audio chunk size in seconds
# JARVIS_SIDECAR_STT_INTERVAL_S=1.0        # Transcription interval
# JARVIS_SIDECAR_STT_OVERLAP_S=0.5         # Overlap between chunks
# JARVIS_SIDECAR_STT_FINAL_MAX_S=12.0      # Max seconds for final flush
# JARVIS_SIDECAR_STT_TIMEOUT_S=20.0        # Per-call timeout
# JARVIS_SIDECAR_STT_FINAL_TIMEOUT_S=45.0  # Final flush timeout
# JARVIS_SIDECAR_STT_LANGUAGE=             # Language hint (e.g., "th-TH")
# JARVIS_SIDECAR_STT_ENABLE_PARTIALS=0   # Enable partial transcripts (0 or 1)

# Image generation models
JARVIS_IMAGEN_MODEL=imagen-4.0-generate-001
JARVIS_IMAGEN_ALLOWED_MODELS=imagen-4.0-generate-001,imagen-4.0-ultra-generate-001,imagen-4.0-fast-generate-001

# -----------------------------------------------------------------------------
# Feature Flags
# -----------------------------------------------------------------------------
# Disable Gemini Live API - forces fallback mode (STT -> HTTP Gemini -> TTS)
JARVIS_DISABLE_GEMINI_LIVE=false

# Probe available models on connect (useful for debugging model availability)
JARVIS_LIVE_PROBE_ON_CONNECT=false

# Fast startup flags - skip loading to reduce startup time
JARVIS_SKIP_AGENTS=1                      # Skip agent .md loading (agents won't route)
JARVIS_SKIP_MEMORY_CACHE=1                  # Skip memory cache initialization

# Enable/disable features
JARVIS_FEATURE_MEMO_ENABLED=true
JARVIS_FEATURE_MEMORY_ENABLED=false
JARVIS_FEATURE_KNOWLEDGE_ENABLED=false
JARVIS_FEATURE_UI_TEST_CARD_ENABLED=false   # Enable test UI card in frontend

# Record WebSocket traffic for debugging (warning: generates large files)
JARVIS_WS_RECORD=1

# -----------------------------------------------------------------------------
# Dialog/Session Configuration
# -----------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0
JARVIS_RECENT_DIALOG_TTL_SECONDS=86400      # 24 hours
JARVIS_RECENT_DIALOG_MAX_TURNS=60
JARVIS_RECENT_DIALOG_MAX_CHARS=4000
JARVIS_SESSION_DB=/data/jarvis_sessions.sqlite

# -----------------------------------------------------------------------------
# Google Sheets Logging
# -----------------------------------------------------------------------------
JARVIS_SHEETS_LOGS_ENABLED=true
JARVIS_SHEETS_LOGS_SHEET_NAME=logs
_JARVIS_SHEETS_LOGS_SPREADSHEET_ID=          # Auto-populated by backend
CHABA_SYSTEM_SHEET_NAME=system
CHABA_SYSTEM_SPREADSHEET_ID=                 # Google Sheet ID for system/config

# -----------------------------------------------------------------------------
# Service URLs (Internal networking)
# -----------------------------------------------------------------------------
MCP_BASE_URL=http://mcp-bundle-assistance:3050
MCP_PLAYWRIGHT_BASE_URL=http://host.docker.internal:4054
DEEP_RESEARCH_WORKER_BASE_URL=http://deep-research-worker:8030
WEB_FETCHER_BASE_URL=http://web-fetcher:8028
WEAVIATE_URL=http://weaviate:8080
GOOGLE_DRIVE_MCP_BASE_URL=http://google-drive-mcp:8032

# -----------------------------------------------------------------------------
# Portainer Integration (for self-management)
# -----------------------------------------------------------------------------
PORTAINER_URL=http://portainer:9000
PORTAINER_TOKEN=                           # API token for Portainer operations
PORTAINER_ENDPOINT_ID=2
PORTAINER_STACK_NAME=idc1-assistance

# -----------------------------------------------------------------------------
# GitHub Integration (for agent operations)
# -----------------------------------------------------------------------------
GITHUB_PERSONAL_TOKEN_RO=                  # Read-only token for agent queries
GITHUB_PERSONAL_TOKEN_RW=                  # Read-write token for agent PRs/issues

# -----------------------------------------------------------------------------
# OAuth Configuration (for Google Sheets integration)
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=                          # OAuth client ID
GOOGLE_CLIENT_SECRET=                     # OAuth client secret
GOOGLE_SHEETS_REDIRECT_URI=https://assistance.idc1.surf-thailand.com/jarvis/api/oauth/callback
GOOGLE_SHEETS_SCOPES=https://www.googleapis.com/auth/spreadsheets

# -----------------------------------------------------------------------------
# Frontend Configuration (for Vite build)
# -----------------------------------------------------------------------------
VITE_JARVIS_WS_URL=wss://assistance.idc1.surf-thailand.com/jarvis/ws/live

# -----------------------------------------------------------------------------
# Asset/Data Directories
# -----------------------------------------------------------------------------
JARVIS_IMAGEN_ASSETS_DIR=/app/imagen_assets
JARVIS_CARS_DATA_DIR=/home/chaba/chaba/services/assistance_data/cars/

# -----------------------------------------------------------------------------
# Google TTS (optional - for fallback voice mode)
# -----------------------------------------------------------------------------
# GOOGLE_TTS_API_KEY=                        # Optional: separate TTS API key
JARVIS_GOOGLE_TTS_LANGUAGE=th-TH            # Default TTS language
JARVIS_GOOGLE_TTS_VOICE=th-TH-Neural2-C     # Default TTS voice

# -----------------------------------------------------------------------------
# Obsolete/Deprecated (kept for reference during migration)
# -----------------------------------------------------------------------------
# These variables are no longer used but documented for cleanup purposes:
# - JARVIS_AGENTS_DIR (now hardcoded to /app/agents)
# - JARVIS_MEMORY_CACHE_TTL_SECONDS (only used when memory cache is enabled)