# idc1-assistance stack environment template (Jarvis frontend+backend)
# Copy to .env (kept out of git) and replace secrets marked __REPLACE_ME__.

# Gemini Developer API key (required)
GEMINI_API_KEY=__REPLACE_ME__

# Optional: override model
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Public base URL used by jarvis-backend to verify the frontend bundle.
# Set to the externally-reachable root of the stack (no trailing slash).
# Required for /jarvis/api/verify/status to check jarvis-frontend markers.
JARVIS_PUBLIC_BASE_URL=https://assistance.idc1.surf-thailand.com

# Optional: override the host used only for the frontend bundle verification check.
# Useful when frontend and backend are on separate origins.
# JARVIS_VERIFY_FRONTEND_BASE_URL=

# Notes:
# - Frontend will be available at http://127.0.0.1:18080/jarvis/
# - Backend health at http://127.0.0.1:18018/health
# - Verify status: GET /jarvis/api/verify/status  (see services/assistance/docs/DEBUG.md)
# - Host Caddy should reverse proxy:
#   /jarvis/* -> 127.0.0.1:18080
#   /jarvis/ws/* -> 127.0.0.1:18018
