# idc1-skill-creator environment configuration
# Copy to .env and fill in your values

# OpenRouter API key for LLM interpretation
# Get from https://openrouter.ai/keys
OPENROUTER_API_KEY=your-api-key-here

# Port mapping (host:container)
SKILL_CREATOR_HOST_PORT=8090
SKILL_CREATOR_CONTAINER_PORT=8080
