# idc1-db Stack Environment Configuration
# Copy to .env and fill in your values (keep .env out of git!)

# PostgreSQL Database
POSTGRES_USER=chaba
POSTGRES_PASSWORD=__REPLACE_ME__
POSTGRES_DB=chaba

# pgAdmin
PGADMIN_EMAIL=admin@chaba.local
PGADMIN_PASSWORD=__REPLACE_ME__

# AutoAgent LLM Configuration
AUTOAGENT_MODEL=openai/gpt-4o-mini
AUTOAGENT_DEBUG=false
AUTOAGENT_API_BASE_URL=https://openrouter.ai/api/v1
AUTOAGENT_FN_CALL=true

# LLM API Keys (at least one required for AutoAgent)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
DEEPSEEK_API_KEY=
GROQ_API_KEY=
XAI_API_KEY=
HUGGINGFACE_API_KEY=

# Wiki API Key (for write operation authentication - generate with: openssl rand -hex 32)
WIKI_API_KEY=
