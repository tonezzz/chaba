{
  "mcpServers": {
    "portainer": {
      "transport": "streamableHttp",
      "url": "http://host.docker.internal:${MCP_BUNDLE_PORT:-3052}/mcp",
      "tags": ["portainer", "containers", "debug"],
      "enabled": true,
      "disabled": false,
      "connectionTimeout": 120000,
      "requestTimeout": 120000,
      "restartOnExit": true,
      "restartDelay": 2000
    }
  }
}
