# gemini-live stack (voice/bidi)
#
# No secrets should be committed. Fill secrets in Portainer stack env or a local .env (gitignored).

# Public URL (TLS terminates at host edge Caddy)
PUBLIC_BASE_URL=https://chaba01.idc1.surf-thailand.com

# Loopback bind for the stack-local caddy (host edge Caddy should reverse proxy to this)
GEMINI_LIVE_HTTP_PORT=18110

# Required
GEMINI_API_KEY=

# Model
GEMINI_LIVE_MODEL=gemini-2.5-flash-native-audio-preview-12-2025

# Hard-coded source URL (HTML or text)
SOURCE_URL=

# Content refresh behavior
SOURCE_REFRESH_TTL_SECONDS=86400

# Live session limits
LIVE_MAX_SESSION_SECONDS=900
LIVE_MAX_SESSIONS_PER_IP=3
LIVE_MAX_CONCURRENT_SESSIONS=10
