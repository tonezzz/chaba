# AutoAgent Test Stack Configuration
# Copy this file to .env and fill in your API keys

# AutoAgent Configuration
AUTOAGENT_HTTP_PORT=8095
AUTOAGENT_MODEL=claude-3-5-sonnet-20241022
AUTOAGENT_DEBUG=false
AUTOAGENT_API_BASE_URL=
AUTOAGENT_FN_CALL=

# LLM API Keys (at least one required)
# OpenAI
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here

# Deepseek
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Groq
GROQ_API_KEY=your_groq_api_key_here

# xAI (Grok)
XAI_API_KEY=your_xai_api_key_here

# Hugging Face
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Optional: GitHub token for git operations
GITHUB_AI_TOKEN=your_github_token_here
