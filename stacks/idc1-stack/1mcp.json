{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/workspaces/chaba"],
      "tags": ["filesystem"],
      "connectionTimeout": 20000,
      "requestTimeout": 60000,
      "restartOnExit": true,
      "restartDelay": 1000
    },
    "docker": {
      "command": "docker-mcp-stdio",
      "tags": ["docker"],
      "connectionTimeout": 120000,
      "requestTimeout": 120000,
      "restartOnExit": true,
      "restartDelay": 2000
    },
    "fetch": {
      "command": "uvx",
      "args": ["mcp-server-fetch"],
      "tags": ["fetch", "web"],
      "connectionTimeout": 30000,
      "requestTimeout": 120000,
      "restartOnExit": true,
      "restartDelay": 1000
    },
    "github": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "tags": ["github"],
      "inheritParentEnv": true,
      "connectionTimeout": 30000,
      "requestTimeout": 120000,
      "restartOnExit": true,
      "restartDelay": 1000
    },
    "glama": {
      "url": "http://mcp-glama:8014/mcp/",
      "type": "streamableHttp",
      "tags": ["glama"],
      "connectionTimeout": 30000,
      "requestTimeout": 120000
    },
    "mcp-memory": {
      "url": "http://mcp-memory-bridge:8470/mcp",
      "tags": ["memory"],
      "connectionTimeout": 30000,
      "requestTimeout": 120000
    }
  }
}
