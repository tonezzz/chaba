FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Install dependencies
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv \
    git wget curl \
    clang-15 cmake build-essential \
    && rm -rf /var/lib/apt/lists/*

# Use clang-15 (available in Ubuntu 22.04)
RUN update-alternatives --install /usr/bin/clang clang /usr/bin/clang-15 100 && \
    update-alternatives --install /usr/bin/clang++ clang++ /usr/bin/clang++-15 100

WORKDIR /workspace

# Clone BitNet with all submodules
RUN git clone --recursive --depth 1 https://github.com/microsoft/BitNet.git .

# Setup Python environment
RUN python3 -m venv /workspace/.venv
ENV PATH="/workspace/.venv/bin:$PATH"
RUN pip install --upgrade pip

# Install requirements first
RUN pip install -r requirements.txt

# Try to run codegen manually first, then build with verbose output
RUN python utils/codegen_tl2.py --model Llama3-8B-1.58-100B-tokens --BM 256,128,256,128 --BK 96,96,96,96 --bm 32,32,32,32 2>&1 || echo "Codegen may have failed, continuing..."

# Run CMake with verbose output to see the actual error
RUN cmake -B build -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ -DCMAKE_VERBOSE_MAKEFILE=ON 2>&1 || (echo "CMake failed"; cat CMakeOutput.log 2>/dev/null; cat CMakeError.log 2>/dev/null; exit 1)

# Try to build with verbose output
RUN cmake --build build --config Release -j4 2>&1 || (echo "Build failed - checking logs:"; find . -name "*.log" -exec cat {} \; 2>/dev/null; exit 1)

CMD ["echo", "Build completed"]
