FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Install dependencies
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv \
    git wget curl \
    clang cmake build-essential \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /workspace

# Clone BitNet
RUN git clone --recursive --depth 1 https://github.com/microsoft/BitNet.git .

# Setup Python environment
RUN python3 -m venv /workspace/.venv
ENV PATH="/workspace/.venv/bin:$PATH"
RUN pip install --upgrade pip setuptools wheel

# Install requirements and build (CPU only)
RUN pip install -r requirements.txt

# Download smallest model (HuggingFace)
RUN pip install huggingface-hub && \
    huggingface-cli download tiiuae/Falcon3-1B-Instruct-1.58bit --local-dir models/falcon3-1b

# Build for CPU
RUN python setup_env.py --hf-repo tiiuae/Falcon3-1B-Instruct-1.58bit -q i2_s

# Test script
CMD ["python", "run_inference.py", "-m", "models/falcon3-1b/ggml-model-i2_s.gguf", "-p", "Hello, how are you?", "-n", "50"]
