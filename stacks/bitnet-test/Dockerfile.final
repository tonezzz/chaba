FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Install dependencies
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv \
    git wget curl \
    clang-15 cmake build-essential \
    && rm -rf /var/lib/apt/lists/*

# Use clang-15 (available in Ubuntu 22.04)
RUN update-alternatives --install /usr/bin/clang clang /usr/bin/clang-15 100 && \
    update-alternatives --install /usr/bin/clang++ clang++ /usr/bin/clang++-15 100

WORKDIR /workspace

# Clone BitNet with all submodules
RUN git clone --recursive --depth 1 https://github.com/microsoft/BitNet.git .

# Setup Python environment
RUN python3 -m venv /workspace/.venv
ENV PATH="/workspace/.venv/bin:$PATH"
RUN pip install --upgrade pip

# Install requirements first
RUN pip install -r requirements.txt

# Run codegen for Falcon3-1B model (x86_64 uses tl2)
RUN python utils/codegen_tl2.py --model Llama3-8B-1.58-100B-tokens --BM 256,128,256,128 --BK 96,96,96,96 --bm 32,32,32,32

# Build bitnet.cpp
RUN cmake -B build -DCMAKE_C_COMPILER=clang -DCMAKE_CXX_COMPILER=clang++ && \
    cmake --build build --config Release -j4

# Download pre-converted GGUF model (Falcon3-1B-Instruct)
RUN pip install huggingface-hub && \
    huggingface-cli download tiiuae/Falcon3-1B-Instruct-1.58bit-GGUF --local-dir models/falcon3-1b-gguf

# Test inference
CMD ["python", "run_inference.py", "-m", "models/falcon3-1b-gguf/ggml-model-i2_s.gguf", "-p", "Explain quantum computing in simple terms", "-n", "100", "-cnv"]
