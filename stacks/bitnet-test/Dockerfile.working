FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive
ENV PYTHONUNBUFFERED=1

# Install dependencies
RUN apt-get update && apt-get install -y \
    python3 python3-pip python3-venv \
    git wget curl \
    clang-15 cmake build-essential \
    && rm -rf /var/lib/apt/lists/*

# Use clang-15 (available in Ubuntu 22.04)
RUN update-alternatives --install /usr/bin/clang clang /usr/bin/clang-15 100 && \
    update-alternatives --install /usr/bin/clang++ clang++ /usr/bin/clang++-15 100

WORKDIR /workspace

# Clone BitNet with all submodules
RUN git clone --recursive --depth 1 https://github.com/microsoft/BitNet.git .

# Setup Python environment
RUN python3 -m venv /workspace/.venv
ENV PATH="/workspace/.venv/bin:$PATH"
RUN pip install --upgrade pip

# Install requirements first
RUN pip install -r requirements.txt

# Run setup_env.py with Falcon3-1B model (supported on x86_64)
# This will download model, generate code, build, and quantize
RUN python setup_env.py --hf-repo tiiuae/Falcon3-1B-Instruct-1.58bit -q i2_s --log-dir /tmp/setup_logs 2>&1 || (cat /tmp/setup_logs/*.log 2>/dev/null; exit 1)

# Test inference
CMD ["python", "run_inference.py", "-m", "models/Falcon3-1B-Instruct-1.58bit/ggml-model-i2_s.gguf", "-p", "Explain quantum computing", "-n", "100", "-cnv"]
